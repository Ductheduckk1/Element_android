<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="SettingRowStyle">
        <item name="android:orientation">horizontal</item>
        <item name="android:paddingVertical">12dp</item>
        <item name="android:paddingHorizontal">8dp</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center_vertical</item>
    </style>

    <style name="SettingRowIcon">
        <item name="android:layout_width">24dp</item>
        <item name="android:layout_height">24dp</item>
        <item name="android:tint">#3B52A1</item>
        <item name="android:layout_marginEnd">12dp</item>
    </style>

    <style name="SettingRowText">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">#000000</item>
    </style>

    <style name="SettingRowChevron">
        <item name="android:layout_width">20dp</item>
        <item name="android:layout_height">20dp</item>
        <item name="android:tint">#888888</item>
    </style>
    <style name="SettingItemStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingHorizontal">16dp</item>
    </style>
    <style name="PinDigitStyle">
        <item name="android:layout_width">56dp</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:background">@drawable/pin_digit_background</item>
        <item name="android:gravity">center</item>
        <item name="android:inputType">number</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">#021B84</item>
        <item name="android:maxLength">1</item>
        <item name="android:textAlignment">center</item>
    </style>


</resources>
